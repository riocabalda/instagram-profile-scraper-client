# Backend origin for production / preview builds (axios baseURL).
# In local dev, leave unset to use relative URLs and the Vite proxy.
# VITE_API_BASE_URL=http://localhost:5000

# Backend URL used by the Vite dev server proxy for /api and /health.
VITE_DEV_API_PROXY=http://localhost:5000

# Optional: POST /trigger-scrape timeout in ms (default 600000).
# VITE_SCRAPER_TIMEOUT_MS=600000
