# Backend origin (axios baseURL). Set on Vercel: Settings → Environment Variables.
# Production example: https://your-api.onrender.com (no trailing slash)
# Leave unset locally to use the Vite dev proxy for /api.
# VITE_API_BASE_URL=https://your-api.onrender.com

# LOCAL DEV ONLY — vite.config.js proxy. Not used in production or by Vercel.
VITE_DEV_API_PROXY=http://localhost:5000

# Optional: POST /trigger-scrape timeout in ms (default 600000).
# VITE_SCRAPER_TIMEOUT_MS=600000
